// firestore.rules
// Deploy with: firebase deploy --only firestore:rules
//
// Rules:
//   - Anyone can READ any municipality document (public map visibility)
//   - Only authenticated admin users can WRITE (create/update/delete)
//
// To get your admin UID:
//   Firebase Console → Authentication → Users → copy UID of your admin account
// Replace "REPLACE_WITH_YOUR_ADMIN_UID" below with that value.

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /municipalities/{municipalityId} {
      // Public read — anyone can view visited status and links
      allow read: if true;

      // Admin write — only the designated admin user
      allow write: if request.auth != null
                   && request.auth.uid == "REPLACE_WITH_YOUR_ADMIN_UID";
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
